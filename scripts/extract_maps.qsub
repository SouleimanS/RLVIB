#!/bin/bash
#PBS -N rlvib_extract_maps
#PBS -P gae50891
#PBS -q rt_HF
#PBS -l select=1
#PBS -l walltime=01:00:00
#PBS -j oe
#PBS -o rlvib_extract_maps.qsub.log

# Extract IB rate maps (per-token KL) from a trained bottleneck. See extract_maps.py.
#   qsub scripts/extract_maps.qsub

set -euo pipefail
cd "$PBS_O_WORKDIR"
mkdir -p "$PBS_O_WORKDIR/runs"

source /home/aab11336im/anaconda3/etc/profile.d/conda.sh
set +u   # rlvib env's activate.d/libstdcxx.sh reads $LD_LIBRARY_PATH unguarded -> set -u aborts
conda activate "${CONDA_ENV:-rlvib}"
set -u
export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:${LD_LIBRARY_PATH:-}"
export CUDA_VISIBLE_DEVICES=0
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export TRANSFORMERS_OFFLINE=1
export PYTHONPATH="$PWD/src:${PYTHONPATH:-}"

echo "=== Node: $(hostname)  Date: $(date) ==="
nvidia-smi -L

exec > >(tee -a "$PBS_O_WORKDIR/runs/extract_maps_out.txt") 2>&1

python -u scripts/extract_maps.py --model "${MODEL:-qwen3-omni}" \
    --ckpt "${CKPT:-runs/bottleneck_swap.pt}" --n "${N:-3}"

echo "=== Done $(date) ==="
