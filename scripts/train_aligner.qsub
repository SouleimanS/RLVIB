#!/bin/bash
#PBS -N rlvib_train_aligner
#PBS -P gae50891
#PBS -q rt_HF
#PBS -l select=1
#PBS -l walltime=01:30:00
#PBS -j oe
#PBS -o rlvib_train_aligner.qsub.log

# Train the audio-visual alignment head on frozen tokens (contrastive). See train_aligner.py.
#   qsub scripts/train_aligner.qsub
#   N=300 EPOCHS=50 qsub -v N,EPOCHS scripts/train_aligner.qsub

set -euo pipefail
cd "$PBS_O_WORKDIR"
mkdir -p "$PBS_O_WORKDIR/runs"

source /home/aab11336im/anaconda3/etc/profile.d/conda.sh
set +u   # rlvib env's activate.d/libstdcxx.sh reads $LD_LIBRARY_PATH unguarded -> set -u aborts
conda activate "${CONDA_ENV:-rlvib}"
set -u
export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:${LD_LIBRARY_PATH:-}"
export CUDA_VISIBLE_DEVICES=0
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export TRANSFORMERS_OFFLINE=1
export PYTHONPATH="$PWD/src:${PYTHONPATH:-}"

echo "=== Node: $(hostname)  Date: $(date) ==="
nvidia-smi -L

exec > >(tee -a "$PBS_O_WORKDIR/runs/train_aligner_out.txt") 2>&1

python -u scripts/train_aligner.py --model "${MODEL:-qwen3-omni}" \
    --n "${N:-150}" --epochs "${EPOCHS:-40}" \
    --margin "${MARGIN:-0.1}" --det-w "${DETW:-1.0}"

echo "=== Done $(date) ==="
