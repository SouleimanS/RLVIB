#!/bin/bash
#PBS -N rlvib_train_grpo
#PBS -P gae50891
#PBS -q rt_HF
#PBS -l select=1
#PBS -l walltime=03:00:00
#PBS -j oe
#PBS -o rlvib_train_grpo.qsub.log

# GRPO over the VIB bottleneck on verifiable yes/no grounding items. See train_grpo.py and
# docs/research/grpo-vib.md.
#   qsub scripts/train_grpo.qsub
#   MODEL=qwen3-omni PAIRS=300 EPOCHS=2 GROUP=8 qsub -v MODEL,PAIRS,EPOCHS,GROUP scripts/train_grpo.qsub
#   GROUP=4 qsub -v GROUP scripts/train_grpo.qsub                 # lower the group size if OOM
#   ABSTAIN=unknown qsub -v ABSTAIN scripts/train_grpo.qsub       # 3-way ternary reward

set -euo pipefail
cd "$PBS_O_WORKDIR"
mkdir -p "$PBS_O_WORKDIR/runs"

source /home/aab11336im/anaconda3/etc/profile.d/conda.sh
set +u                                            # conda activate.d hooks aren't `set -u`-safe
conda activate "${CONDA_ENV:-rlvib}"
set -u
export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:${LD_LIBRARY_PATH:-}"
export CUDA_VISIBLE_DEVICES=0
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export TRANSFORMERS_OFFLINE=1
export PYTHONPATH="$PWD/src:${PYTHONPATH:-}"

echo "=== Node: $(hostname)  Date: $(date) ==="
nvidia-smi -L

exec > >(tee -a "$PBS_O_WORKDIR/runs/train_grpo_${MODEL:-qwen3-omni}_out.txt") 2>&1

python -u scripts/train_grpo.py --model "${MODEL:-qwen3-omni}" \
    --pairs "${PAIRS:-300}" --epochs "${EPOCHS:-2}" --accum "${ACCUM:-1}" \
    --group "${GROUP:-8}" --lr "${LR:-5e-5}" --beta-kl "${BETAKL:-0.01}" \
    --lam-ref "${LAMREF:-0.05}" --seed "${SEED:-0}" --eval-every "${EVALEVERY:-10}" \
    ${ABSTAIN:+--abstain-token "$ABSTAIN"} ${STD_ADV:+--std-adv} \
    --save-dir "runs/anchored_${MODEL:-qwen3-omni}_grpo"

echo "=== Done $(date) ==="
