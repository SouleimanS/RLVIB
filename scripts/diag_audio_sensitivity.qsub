#!/bin/bash
#PBS -N rlvib_diag_audio
#PBS -P gae50891
#PBS -q rt_HF
#PBS -l select=1
#PBS -l walltime=01:00:00
#PBS -j oe
#PBS -o rlvib_diag_audio.qsub.log

# Diagnose whether AVE-MCQ answers depend on audio (base model, no bottleneck).
# Tells us if the audio-drop DPO counterfactual has any signal. See the .py header.
#   qsub scripts/diag_audio_sensitivity.qsub

set -euo pipefail
cd "$PBS_O_WORKDIR"
mkdir -p "$PBS_O_WORKDIR/runs"

source /home/aab11336im/anaconda3/etc/profile.d/conda.sh
set +u   # rlvib env's activate.d/libstdcxx.sh reads $LD_LIBRARY_PATH unguarded -> set -u aborts
conda activate "${CONDA_ENV:-rlvib}"
set -u
export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:${LD_LIBRARY_PATH:-}"
export CUDA_VISIBLE_DEVICES=0
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export TRANSFORMERS_OFFLINE=1
export PYTHONPATH="$PWD/src:${PYTHONPATH:-}"

echo "=== Node: $(hostname)  Date: $(date) ==="
nvidia-smi -L

exec > >(tee -a "$PBS_O_WORKDIR/runs/diag_audio_out.txt") 2>&1

python -u scripts/diag_audio_sensitivity.py --model "${MODEL:-qwen3-omni}" --n "${N:-8}"

echo "=== Done $(date) ==="
